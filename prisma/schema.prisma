generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User
model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String       @map("password_hash")
  status       UserStatus   @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  memberships  Membership[]
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Business
model Business {
  id                   String               @id @default(cuid())
  name                 String
  type                 String
  timeZone             String               @map("time_zone")
  contactEmail         String               @map("contact_email")
  contactPhone         String?              @map("contact_phone")
  address              String?
  bookingWindowDays    Int                  @default(30) @map("booking_window_days")
  advanceBookingHours  Int                  @default(24) @map("advance_booking_hours")
  cancellationHours    Int                  @default(24) @map("cancellation_hours")
  defaultDuration      Int                  @default(60) @map("default_duration")
  status               BusinessStatus       @default(ACTIVE)
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  memberships          Membership[]
  services             Service[]
  weeklySchedules      WeeklySchedule[]
  holidays             Holiday[]
  @@map("businesses")
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Membership
model Membership {
  id         String           @id @default(cuid())
  userId     String           @map("user_id")
  businessId String           @map("business_id")
  role       MembershipRole   @default(OWNER)
  status     MembershipStatus @default(ACTIVE)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  @@unique([userId, businessId])
  @@map("memberships")
}

enum MembershipRole {
  OWNER
  MANAGER
  STAFF
  RECEPTIONIST
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  INVITED
}

// Session
model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  @@index([token])
  @@index([userId])
  @@map("sessions")
}

// Service
model Service {
  id          String        @id @default(cuid())
  businessId  String        @map("business_id")
  name        String
  description String?
  duration    Int
  status      ServiceStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  @@map("services")
}

enum ServiceStatus {
  ACTIVE
  ARCHIVED
}

// WeeklySchedule
model WeeklySchedule {
  id          String    @id @default(cuid())
  businessId  String    @map("business_id")
  dayOfWeek   Int       @map("day_of_week")
  isOpen      Boolean   @default(true) @map("is_open")
  openTime    String    @map("open_time")
  closeTime   String    @map("close_time")
  breaks      Break[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  @@unique([businessId, dayOfWeek])
  @@map("weekly_schedules")
}

// Break
model Break {
  id               String         @id @default(cuid())
  weeklyScheduleId String         @map("weekly_schedule_id")
  startTime        String         @map("start_time")
  endTime          String         @map("end_time")
  label            String?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  weeklySchedule   WeeklySchedule @relation(fields: [weeklyScheduleId], references: [id], onDelete: Cascade)
  @@map("breaks")
}

// Holiday
model Holiday {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  date       DateTime
  label      String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  @@map("holidays")
}
