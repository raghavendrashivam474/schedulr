generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String       @map("password_hash")
  status       UserStatus   @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  memberships  Membership[]
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Business {
  id                  String         @id @default(cuid())
  name                String
  slug                String?        @unique
  type                String
  description         String?
  logoUrl             String?        @map("logo_url")
  coverImageUrl       String?        @map("cover_image_url")
  website             String?
  instagram           String?
  facebook            String?
  timeZone            String         @map("time_zone")
  contactEmail        String         @map("contact_email")
  contactPhone        String?        @map("contact_phone")
  address             String?
  bookingWindowDays   Int            @default(30) @map("booking_window_days")
  advanceBookingHours Int            @default(24) @map("advance_booking_hours")
  cancellationHours   Int            @default(24) @map("cancellation_hours")
  defaultDuration     Int            @default(60) @map("default_duration")
  status              BusinessStatus @default(ACTIVE)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  memberships         Membership[]
  services            Service[]
  weeklySchedules     WeeklySchedule[]
  holidays            Holiday[]
  bookings            Booking[]
  customers           Customer[]
  @@index([slug])
  @@map("businesses")
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Membership {
  id         String           @id @default(cuid())
  userId     String           @map("user_id")
  businessId String           @map("business_id")
  role       MembershipRole   @default(OWNER)
  status     MembershipStatus @default(ACTIVE)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  @@unique([userId, businessId])
  @@map("memberships")
}

enum MembershipRole {
  OWNER
  MANAGER
  STAFF
  RECEPTIONIST
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  INVITED
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model Service {
  id          String        @id @default(cuid())
  businessId  String        @map("business_id")
  name        String
  description String?
  duration    Int
  status      ServiceStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  @@map("services")
}

enum ServiceStatus {
  ACTIVE
  ARCHIVED
}

model WeeklySchedule {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  dayOfWeek  Int      @map("day_of_week")
  isOpen     Boolean  @default(true) @map("is_open")
  openTime   String   @map("open_time")
  closeTime  String   @map("close_time")
  breaks     Break[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  @@unique([businessId, dayOfWeek])
  @@map("weekly_schedules")
}

model Break {
  id               String         @id @default(cuid())
  weeklyScheduleId String         @map("weekly_schedule_id")
  startTime        String         @map("start_time")
  endTime          String         @map("end_time")
  label            String?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  weeklySchedule   WeeklySchedule @relation(fields: [weeklyScheduleId], references: [id], onDelete: Cascade)
  @@map("breaks")
}

model Holiday {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  date       DateTime
  label      String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  @@map("holidays")
}

model Customer {
  id          String    @id @default(cuid())
  businessId  String    @map("business_id")
  name        String
  email       String
  phone       String?
  notes       String?
  firstVisit  DateTime? @map("first_visit")
  lastVisit   DateTime? @map("last_visit")
  totalVisits Int       @default(0) @map("total_visits")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  timeline    AppointmentTimeline[]
  @@unique([businessId, email])
  @@index([businessId])
  @@map("customers")
}

model Booking {
  id              String        @id @default(cuid())
  businessId      String        @map("business_id")
  serviceId       String        @map("service_id")
  customerId      String?       @map("customer_id")
  customerName    String        @map("customer_name")
  customerEmail   String        @map("customer_email")
  customerPhone   String?       @map("customer_phone")
  appointmentDate DateTime      @map("appointment_date")
  startTime       String        @map("start_time")
  endTime         String        @map("end_time")
  status          BookingStatus @default(CONFIRMED)
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service         Service       @relation(fields: [serviceId], references: [id])
  customer        Customer?     @relation(fields: [customerId], references: [id])
  timeline        AppointmentTimeline[]
  @@index([businessId, appointmentDate])
  @@index([customerEmail])
  @@map("bookings")
}

enum BookingStatus {
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model AppointmentTimeline {
  id          String        @id @default(cuid())
  bookingId   String        @map("booking_id")
  customerId  String?       @map("customer_id")
  status      BookingStatus
  note        String?
  performedBy String?       @map("performed_by")
  createdAt   DateTime      @default(now()) @map("created_at")
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer    Customer?     @relation(fields: [customerId], references: [id])
  @@map("appointment_timeline")
}
